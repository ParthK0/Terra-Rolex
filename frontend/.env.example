# ═══════════════════════════════════════════════════════════════════════════════
#  TerraRolex — Frontend Environment Variables (.env.example)
#  Vite exposes only variables prefixed with VITE_ to the browser bundle.
#  Copy this file to .env.local and fill in your values.
#  Never commit .env.local to git.
# ═══════════════════════════════════════════════════════════════════════════════


# ─── CURRENTLY IN USE ──────────────────────────────────────────────────────────

# [REQUIRED] Firebase Web SDK — client-side Auth and Firestore access.
#            Get all values from: Firebase Console → Project Settings → Your Apps
#            → Add App → Web → Register App → copy the firebaseConfig object.
VITE_FIREBASE_API_KEY=your_firebase_web_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxxxxxxxxxx

# [REQUIRED] Backend API base URL.
#            Local dev: FastAPI runs on 8000 by default.
#            Production: replace with your deployed API URL.
VITE_API_BASE_URL=http://localhost:8000


# ─── PHASE 2: WEATHER-AWARE SKY ───────────────────────────────────────────────

# [RECOMMENDED] OpenWeatherMap API Key — fetched client-side to set the sky
#               background filter to match actual local weather in real time.
#               Free tier: 1,000 calls/day. No credit card required.
#               Get yours at: https://openweathermap.org/api → Current Weather Data
VITE_OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here


# ─── PHASE 3: GOOGLE MAPS (commute autocomplete) ──────────────────────────────

# [OPTIONAL] Google Maps JavaScript API Key — enables the Places Autocomplete
#            widget for city/address search in onboarding and commute logging.
#            Restrict this key to your domain in the Google Cloud Console.
#            Get yours at: https://console.cloud.google.com/apis/credentials
#            Enable: Maps JavaScript API + Places API (New)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here


# ─── PHASE 3: NASA GLOBE TILES ────────────────────────────────────────────────

# [OPTIONAL] NASA Earthdata Bearer Token — fetches real satellite CO₂
#            concentration tiles to overlay on the globe visualization.
#            Register free at: https://urs.earthdata.nasa.gov/users/new
VITE_NASA_EARTHDATA_TOKEN=your_nasa_earthdata_token_here


# ─── APP CONFIG ────────────────────────────────────────────────────────────────

# App environment label. Used to gate debug panels and verbose logging in UI.
# Options: development | production
VITE_APP_ENV=development

# App version shown in the footer and error reports.
VITE_APP_VERSION=1.0.0
