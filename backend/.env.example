# ═══════════════════════════════════════════════════════════════════════════════
#  TerraRolex — Backend Environment Variables
#  Copy this file to .env and fill in your values.
#  Never commit .env to git.
# ═══════════════════════════════════════════════════════════════════════════════


# ─── CURRENTLY IN USE ──────────────────────────────────────────────────────────

# [REQUIRED] Google Gemini API Key — used for AI coaching nudges and
#            challenge generation. Get yours at:
#            https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# [OPTIONAL] Firebase Admin SDK service-account JSON path.
#            If missing, the backend falls back to the local mock JSON database.
#            Download from: Firebase Console → Project Settings → Service Accounts
FIREBASE_CREDENTIALS_PATH=path/to/firebase-credentials.json

# [OPTIONAL] Comma-separated list of allowed frontend origins for CORS.
#            Defaults to Vite dev + preview ports if not set.
#            In production set this to your deployed frontend URL.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173,https://your-production-domain.com


# ─── PHASE 2: WEATHER-AWARE SKY & NUDGES ──────────────────────────────────────

# [RECOMMENDED] OpenWeatherMap API Key — used to fetch real-time local weather
#               so the dashboard sky matches actual conditions and nudges are
#               temperature-aware ("It's 38°C — AC usage will spike today").
#               Free tier: 1,000 calls/day. No credit card required.
#               Get yours at: https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here

# [OPTIONAL] Default city coordinates used when user location is unavailable.
#            Format: "latitude,longitude"
DEFAULT_LOCATION_LAT=28.6139
DEFAULT_LOCATION_LNG=77.2090


# ─── PHASE 2: LIVE AIR QUALITY (OpenAQ) ───────────────────────────────────────

# OpenAQ is FREE with no API key required for basic v3 endpoints.
# Advanced endpoints (higher rate limits) require registration at:
# https://explore.openaq.org/register
# Leave blank to use the anonymous public tier.
OPENAQ_API_KEY=


# ─── PHASE 3: SATELLITE CO₂ DATA (NASA EARTHDATA) ─────────────────────────────

# [OPTIONAL] NASA Earthdata Bearer Token — used to fetch real OCO-2 satellite
#            CO₂ concentration tiles for the globe visualization.
#            Register free at: https://urs.earthdata.nasa.gov/users/new
#            Then generate a token at: https://urs.earthdata.nasa.gov/profile
NASA_EARTHDATA_TOKEN=your_nasa_earthdata_token_here

# [OPTIONAL] NASA GIBS tile layer to overlay on the globe.
#            Default: OCO-2 XCO2 (carbon dioxide column average mixing ratio)
#            Other options: MODIS_Terra_Aerosol, VIIRS_SNPP_CorrectedReflectance
NASA_GIBS_LAYER=OCO2_XCO2_Annual


# ─── PHASE 3: ROUTE-BASED COMMUTE DISTANCE (Google Maps) ──────────────────────

# [OPTIONAL] Google Maps Platform API Key — used for the Directions API to
#            calculate exact driving/cycling distances instead of manual km entry.
#            Also unlocks Places Autocomplete for city selection in onboarding.
#            Free credit: $200/month. Requires billing enabled.
#            Get yours at: https://console.cloud.google.com/apis/credentials
#            Enable: Directions API + Places API (New)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here


# ─── PHASE 4: PERFORMANCE — REDIS CACHE ───────────────────────────────────────

# [OPTIONAL] Redis connection URL — caches Gemini AI nudges per user (6-hour TTL)
#            so most dashboard loads skip the 300ms Gemini call entirely.
#            Local dev: use Redis via Docker → docker run -p 6379:6379 redis:alpine
#            Cloud options: Upstash (free tier), Redis Cloud, Railway
REDIS_URL=redis://localhost:6379/0


# ─── PHASE 4: TIME-SERIES ANALYTICS (Supabase / PostgreSQL) ───────────────────

# [OPTIONAL] PostgreSQL connection string for long-range chart queries
#            (30-day, 90-day emission trends). Supabase has a generous free tier.
#            Get yours at: https://supabase.com/dashboard/projects → Settings → Database
#            Leave blank to keep using Firestore for all storage.
DATABASE_URL=postgresql://user:password@localhost:5432/terrarolex


# ─── APP CONFIG ────────────────────────────────────────────────────────────────

# Environment label. Controls logging verbosity and error detail in responses.
# Options: development | production
APP_ENV=development

# Backend API port (Uvicorn default is 8000)
PORT=8000
